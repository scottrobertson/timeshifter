# Your Xtream Codes panel base URL, including the port. No trailing slash.
# Example: http://my-provider.com:8080
IPTV_URL=
IPTV_USERNAME=
IPTV_PASSWORD=

# Where downloads are saved. Defaults to ./downloads
# DOWNLOAD_DIR=./downloads

# User agent sent with every request. Defaults to a VLC string, since many
# panels drop connections from clients that don't look like a real player.
# Override it here if your provider expects something specific.
# IPTV_USER_AGENT=VLC/3.0.18 LibVLC/3.0.18

# Timeshift URL style. Most panels use "path". A few older ones use "php".
# Defaults to path.
# TIMESHIFT_MODE=path

# Padding (in minutes) added before the start and after the end of each
# recording, in case the guide times are slightly off. Both default to 0.
# A negative number does the opposite (starts late, ends early). These are the
# defaults; you can also change them per-download from the confirm prompt.
# PADDING_BEFORE_MINUTES=0
# PADDING_AFTER_MINUTES=0

# Output filename template. Available tokens:
#   {channel}  channel name
#   {title}    program title
#   {date}     YYYY-MM-DD
#   {time}     HH-MM
#   {datetime} YYYY-MM-DD_HH-MM
#   {ext}      file extension (always ts)
# You can include subfolders, e.g. "{channel}/{title} - {date}.{ext}".
# Defaults to "{channel} - {title} - {datetime}.{ext}".
# FILENAME_TEMPLATE={channel} - {title} - {datetime}.{ext}

# Set the downloaded file's modified time to when the show aired, so it sorts by
# air date in a media library. Defaults to true. Set to false to keep the normal
# download time. (For Emby/Jellyfin, set "date added behavior" to use the file date.)
# SET_AIRED_TIME=true

# Path to the subscriptions file used by `watch` mode. Defaults to
# ./subscriptions.json. See subscriptions.example.json for the format.
# SUBSCRIPTIONS_FILE=subscriptions.json

# Timezone for the log timestamps in watch mode (the Docker image includes the
# zone data). Defaults to UTC. Guide and recording times are unaffected; they
# always use the provider's own local time.
# TZ=Europe/London
