# Configure ONE of the two options below: an M3U playlist URL, or the Xtream
# Codes API details. The M3U option works with any provider; the Xtream API
# option is a bit quicker since it doesn't download a large EPG.

# Option 1: an M3U playlist URL. Channels with catchup are read from it. For the
# guide: if the playlist is Xtream-backed (its stream URLs contain the host,
# username and password), the provider's API is used so you get the full past
# guide. Otherwise the playlist's EPG (url-tvg) is used, which often only lists
# upcoming programs, not past ones.
# M3U_URL=

# Optional: override the XMLTV guide URL (defaults to the playlist's url-tvg).
# Only used for non-Xtream playlists.
# EPG_URL=

# Option 2: Xtream Codes API. Base URL including the port, no trailing slash.
# Example: http://my-provider.com:8080
IPTV_URL=
IPTV_USERNAME=
IPTV_PASSWORD=

# Where downloads are saved. Defaults to ./downloads
# DOWNLOAD_DIR=./downloads

# Output container. "ts" saves the raw stream as-is (no remux, safest, plays in
# VLC/Plex). "mp4" remuxes for wider compatibility. Defaults to ts.
# OUTPUT_FORMAT=ts

# Some providers reject requests without a known player user agent.
# If downloads fail with 403/forbidden, try setting this.
# IPTV_USER_AGENT=VLC/3.0.18 LibVLC/3.0.18

# Timeshift URL style. Most panels use "path". A few older ones use "php".
# Defaults to path.
# TIMESHIFT_MODE=path

# Padding (in minutes) added before the start and after the end of each
# recording, in case the guide times are slightly off. Both default to 0.
# PADDING_BEFORE_MINUTES=2
# PADDING_AFTER_MINUTES=5

# Output filename template. Available tokens:
#   {channel}  channel name
#   {title}    program title
#   {date}     YYYY-MM-DD
#   {time}     HH-MM
#   {datetime} YYYY-MM-DD_HH-MM
#   {ext}      output container (ts/mp4)
# You can include subfolders, e.g. "{channel}/{title} - {date}.{ext}".
# Defaults to "{channel} - {title} - {datetime}.{ext}".
# FILENAME_TEMPLATE={channel} - {title} - {datetime}.{ext}

# Show ffmpeg's full raw output (stream info, corrupt-packet warnings, etc.)
# instead of a clean progress line. Useful for debugging. Defaults to false.
# VERBOSE=false
