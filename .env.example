# Your Xtream Codes panel base URL, including the port. No trailing slash.
# Example: http://my-provider.com:8080
IPTV_URL=

IPTV_USERNAME=
IPTV_PASSWORD=

# Where downloads are saved. Defaults to ./downloads
# DOWNLOAD_DIR=./downloads

# Output container. "ts" saves the raw stream as-is (no remux, safest, plays in
# VLC/Plex). "mp4" remuxes for wider compatibility. Defaults to ts.
# OUTPUT_FORMAT=ts

# Some providers reject requests without a known player user agent.
# If downloads fail with 403/forbidden, try setting this.
# IPTV_USER_AGENT=VLC/3.0.18 LibVLC/3.0.18

# Timeshift URL style. Most panels use "path". A few older ones use "php".
# Defaults to path.
# TIMESHIFT_MODE=path

# Padding (in minutes) added before the start and after the end of each
# recording, in case the guide times are slightly off. Both default to 0.
# PADDING_BEFORE_MINUTES=2
# PADDING_AFTER_MINUTES=5

# Output filename template. Available tokens:
#   {channel}  channel name
#   {title}    program title
#   {date}     YYYY-MM-DD
#   {time}     HH-MM
#   {datetime} YYYY-MM-DD_HH-MM
#   {ext}      output container (ts/mp4)
# You can include subfolders, e.g. "{channel}/{title} - {date}.{ext}".
# Defaults to "{channel} - {title} - {datetime}.{ext}".
# FILENAME_TEMPLATE={channel} - {title} - {datetime}.{ext}
