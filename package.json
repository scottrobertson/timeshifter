{
  "name": "timeshifter",
  "version": "0.1.0",
  "description": "Download timeshifted (catchup) recordings from an Xtream Codes IPTV provider by picking a show from the EPG.",
  "type": "module",
  "bin": {
    "timeshifter": "src/index.ts"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
