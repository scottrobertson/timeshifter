{
  "name": "timeshifter",
  "version": "0.1.0",
  "description": "Download timeshifted (catchup) recordings from an Xtream Codes IPTV provider by picking a show from the EPG.",
  "type": "module",
  "bin": {
    "timeshifter": "src/index.ts"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test --test-isolation=none tests/*.test.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
}
